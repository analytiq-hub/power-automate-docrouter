{
  "properties": {
    "connectionParameters": {
      "api_key": {
        "type": "securestring",
        "uiDefinition": {
          "displayName": "API Key",
          "description": "Your DocRouter API key. Create one under Settings → Developer in the DocRouter app.",
          "tooltip": "Provide your DocRouter API key",
          "constraints": {
            "tabIndex": 2,
            "clearText": false,
            "required": "true"
          }
        }
      },
      "organization_id": {
        "type": "string",
        "uiDefinition": {
          "displayName": "Organization ID",
          "description": "Your DocRouter organization ID. Find it in the DocRouter app under Settings → Organization.",
          "tooltip": "Provide your DocRouter organization ID",
          "constraints": {
            "tabIndex": 3,
            "clearText": false,
            "required": "true"
          }
        }
      },
      "base_url": {
        "type": "string",
        "defaultValue": "https://app.docrouter.ai/fastapi",
        "uiDefinition": {
          "displayName": "Base URL",
          "description": "Base URL of your DocRouter instance, e.g. https://app.docrouter.ai/fastapi. Change only for on-premises deployments.",
          "tooltip": "Provide the base URL of your DocRouter instance",
          "constraints": {
            "tabIndex": 4,
            "clearText": false,
            "required": "true"
          }
        }
      }
    },
    "iconBrandColor": "#2563EB",
    "capabilities": [],
    "policyTemplateInstances": [
      {
        "templateId": "dynamichosturl",
        "title": "Set base URL from connection",
        "parameters": {
          "x-ms-apimTemplateParameter.urlTemplate": "@connectionParameters('base_url')"
        }
      }
    ],
    "publisher": "Analytiq Hub LLC",
    "stackOwner": "DocRouter"
  }
}
