{
  "properties": {
    "connectionParameters": {
      "api_key": {
        "type": "securestring",
        "uiDefinition": {
          "displayName": "API Key",
          "description": "Your DocRouter API key. Create one under Settings → Developer in the DocRouter app.",
          "tooltip": "Provide your DocRouter API key",
          "constraints": {
            "tabIndex": 2,
            "clearText": false,
            "required": "true"
          }
        }
      },
      "docrouter_organization_id": {
        "type": "string",
        "uiDefinition": {
          "displayName": "Organization ID",
          "description": "Your DocRouter organization ID (used for all actions on this connection). In the DocRouter web app, open the URL in your browser: it looks like https://app.docrouter.ai/orgs/{organization_id}/... — copy the segment after /orgs/ (for example, 679c9a914cfaaaa3640811ed). You can also find it under Settings → Organization.",
          "tooltip": "Copy the ID from the path after /orgs/ in your DocRouter URL (e.g. https://app.docrouter.ai/orgs/679c9a914cfaaaa3640811ed/docs)",
          "constraints": {
            "tabIndex": 3,
            "clearText": false,
            "required": "true"
          }
        }
      },
      "base_url": {
        "type": "string",
        "uiDefinition": {
          "displayName": "Base URL (optional)",
          "description": "Base URL of your DocRouter instance. Leave blank to use the default (https://app.docrouter.ai/fastapi).",
          "tooltip": "Optional. Default: https://app.docrouter.ai/fastapi",
          "default": "https://app.docrouter.ai/fastapi",
          "constraints": {
            "tabIndex": 4,
            "clearText": true,
            "required": "false"
          }
        }
      }
    },
