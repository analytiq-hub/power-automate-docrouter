    "title": "DocRouter Account",
    "description": "DocRouter account-scoped APIs under /v0/account/: manage users, organizations, account-level API tokens, AWS integration, and LLM provider configuration. Authenticate with an account-level API token (prefix acc_, no organization binding) via X-Api-Key \u2014 create one in the DocRouter app under Settings \u2192 Developer. Organization-scoped tokens (org_...) cannot call these paths.",
    "version": "1.0",
    "contact": {
      "name": "DocRouter Support",
      "url": "https://docrouter.ai",
      "email": "support@docrouter.ai"
    }
  },
  "host": "app.docrouter.ai",
  "basePath": "/fastapi",
