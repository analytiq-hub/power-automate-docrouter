        "description": "List organizations visible to the token, filter by user or single org id, or search by name/member. Requires appropriate permissions.",
        "x-ms-summary": "List organizations",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": false,
            "type": "string",
            "x-ms-summary": "User Id",
            "description": "Filter by user ID (admin or self)."
          },
          {
            "name": "organization_id",
            "in": "query",
            "required": false,
            "type": "string",
            "x-ms-summary": "Organization Id",
            "description": "Return a single organization by ID."
          },
          {
            "name": "name_search",
            "in": "query",
            "required": false,
            "type": "string",
            "x-ms-summary": "Name Search",
            "description": "Case-insensitive name search."
          },
          {
            "name": "member_search",
            "in": "query",
            "required": false,
            "type": "string",
            "x-ms-summary": "Member Search",
            "description": "Case-insensitive member name or email search."
          },
          {
            "name": "skip",
            "in": "query",
            "required": false,
            "type": "integer",
            "x-ms-summary": "Skip",
            "description": "Pagination offset.",
            "format": "int32",
            "default": 0
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "x-ms-summary": "Limit",
            "description": "Page size (1\u2013100).",
            "format": "int32",
            "default": 10
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": {
              "$ref": "#/definitions/ListOrganizationsResponse"
            }
          }
        }
      },
      "post": {
        "operationId": "CreateOrganization",
        "summary": "Create organization",
        "description": "Create a new organization; the current user becomes an admin member.",
        "x-ms-summary": "Create organization",
        "parameters": [
          {
