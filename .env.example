# Power Automate connector IDs assigned after first deploy (paconn create).
# Used by docrouter/docrouter-org/update.sh and download.sh
ORG_CONNECTOR_ID=
# Used by docrouter/docrouter-account/update.sh and download.sh
ACCOUNT_CONNECTOR_ID=

# Power Platform environment GUID (Azure portal / PP admin center).
# Used by download.sh (and paconn create/update when not passed on the command line).
POWER_PLATFORM_ENVIRONMENT_ID=

# Path to an external connector directory (e.g. from ../PowerPlatformConnectors).
# Used by external-connectors/create.sh, update.sh, and validate.sh.
EXTERNAL_CONNECTOR_DIR="../PowerPlatformConnectors/independent-publisher-connectors/Bluesky Social"

# Connector ID for testing external connectors from ../PowerPlatformConnectors.
# Used by external-connectors/update.sh.
EXTERNAL_CONNECTOR_ID=
